# Local development only. Copy to .env and fill values outside Git.

# Postgres warehouse/search database
DATABASE_URL=postgresql://madtitan:madtitan@localhost:5432/madtitan_bestiary
POSTGRES_USER=madtitan
POSTGRES_PASSWORD=madtitan
POSTGRES_DB=madtitan_bestiary

# Local private source mirror. This path must stay outside the repo.
LOCAL_PDF_MIRROR=/absolute/path/to/private/bestiary-pdfs

# Optional private R2 mirror
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Web auth allowlist
AUTH_SECRET=replace-with-local-secret
AUTH_ALLOWED_EMAILS=dm@example.com
