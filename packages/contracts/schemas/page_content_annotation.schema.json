        "x0": {
          "title": "X0",
          "type": "number"
        },
        "y0": {
          "title": "Y0",
          "type": "number"
        },
        "x1": {
          "title": "X1",
          "type": "number"
        },
        "y1": {
          "title": "Y1",
          "type": "number"
