    "annotation_id": {
      "title": "Annotation Id",
      "type": "string"
    },
    "extracted_page_text_id": {
      "title": "Extracted Page Text Id",
      "type": "string"
    },
    "source_book_id": {
      "title": "Source Book Id",
      "type": "string"
    },
