        "xp": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Xp"
        },
        "proficiency_bonus": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
