          "default": "ft",
          "title": "Reach Unit"
        },
        "range_normal": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Range Normal"
        },
        "range_long": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Range Long"
        },
        "damage": {
          "items": {
            "$ref": "#/$defs/DamageInstance"
          },
          "title": "Damage",
          "type": "array"
        },
        "target_size_limit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Size Limit"
        }
      },
      "title": "AttackDetail",
      "type": "object"
    },
    "Challenge": {
      "properties": {
        "rating": {
          "title": "Rating",
          "type": "string"
