        "name",
        "kind",
        "text"
      ],
      "title": "MonsterFeature",
      "type": "object"
    },
    "MovementSpeed": {
      "description": "A speed entry. Unlabeled stat-block speed should use mode='walk'.",
      "properties": {
        "mode": {
          "default": "walk",
          "title": "Mode",
          "type": "string"
        },
        "distance": {
          "minimum": 0,
          "title": "Distance",
