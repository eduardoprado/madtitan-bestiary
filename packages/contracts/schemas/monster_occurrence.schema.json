          "default": null,
          "title": "Book Title"
        },
        "ruleset": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ruleset"
        },
        "page_start": {
          "minimum": 1,
          "title": "Page Start",
          "type": "integer"
        },
        "page_end": {
          "minimum": 1,
          "title": "Page End",
          "type": "integer"
        },
        "extraction_method": {
          "title": "Extraction Method",
          "type": "string"
        },
        "parser_version": {
          "title": "Parser Version",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_title",
        "page_start",
        "page_end",
        "extraction_method",
        "parser_version"
      ],
      "title": "SourceProvenance",
      "type": "object"
    }
