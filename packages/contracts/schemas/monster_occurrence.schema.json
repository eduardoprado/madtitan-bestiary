      "required": [
        "distance"
      ],
      "title": "MovementSpeed",
      "type": "object"
    },
    "Sense": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "distance": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Distance"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
