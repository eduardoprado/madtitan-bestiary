          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "ArmorClass",
      "type": "object"
    },
    "AttackDetail": {
      "properties": {
        "attack_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
