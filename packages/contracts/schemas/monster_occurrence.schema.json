{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://madtitan.local/schemas/monster_occurrence.schema.json",
  "title": "MonsterOccurrence",
  "type": "object",
  "required": ["name", "size", "creature_type", "provenance", "confidence"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "size": { "type": "string", "minLength": 1 },
    "creature_type": { "type": "string", "minLength": 1 },
    "alignment": { "type": ["string", "null"] },
    "challenge_rating": { "type": ["string", "null"] },
    "armor_class": { "type": ["integer", "null"], "minimum": 0 },
    "hit_points": { "type": ["integer", "null"], "minimum": 0 },
    "abilities": {
      "type": ["object", "null"],
      "required": [
        "str_score",
        "dex_score",
        "con_score",
        "int_score",
        "wis_score",
        "cha_score"
      ],
      "properties": {
        "str_score": { "type": "integer", "minimum": 1, "maximum": 30 },
        "dex_score": { "type": "integer", "minimum": 1, "maximum": 30 },
        "con_score": { "type": "integer", "minimum": 1, "maximum": 30 },
        "int_score": { "type": "integer", "minimum": 1, "maximum": 30 },
        "wis_score": { "type": "integer", "minimum": 1, "maximum": 30 },
        "cha_score": { "type": "integer", "minimum": 1, "maximum": 30 }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "text"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "provenance": {
      "type": "object",
      "required": [
        "source_id",
        "source_title",
        "page_start",
        "page_end",
        "extraction_method",
        "parser_version"
      ],
      "properties": {
        "source_id": { "type": "string" },
        "source_title": { "type": "string" },
        "page_start": { "type": "integer", "minimum": 1 },
        "page_end": { "type": "integer", "minimum": 1 },
        "extraction_method": { "type": "string" },
        "parser_version": { "type": "string" }
      }
    },
    "raw_json": { "type": "object" }
  }
}
