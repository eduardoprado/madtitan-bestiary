        "damage_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Damage Type"
        }
      },
      "title": "DamageInstance",
      "type": "object"
    },
    "DiceFormula": {
      "description": "Parsed dice expression such as 3d10+6.",
      "properties": {
        "raw": {
          "title": "Raw",
          "type": "string"
        },
        "quantity": {
          "minimum": 0,
          "title": "Quantity",
          "type": "integer"
        },
        "die_type": {
          "pattern": "^d\\d+$",
          "title": "Die Type",
          "type": "string"
        },
        "modifier": {
          "default": 0,
          "title": "Modifier",
          "type": "integer"
        }
      },
      "required": [
        "raw",
        "quantity",
        "die_type"
      ],
      "title": "DiceFormula",
      "type": "object"
    },
    "Initiative": {
