{
  "$defs": {
    "AbilityBlock": {
      "properties": {
        "score": {
          "maximum": 30,
          "minimum": 1,
          "title": "Score",
          "type": "integer"
        },
        "modifier": {
          "title": "Modifier",
          "type": "integer"
        },
        "saving_throw": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Saving Throw"
        }
      },
      "required": [
        "score",
        "modifier"
      ],
      "title": "AbilityBlock",
      "type": "object"
    },
    "AbilityScores": {
      "properties": {
        "str": {
          "$ref": "#/$defs/AbilityBlock"
        },
        "dex": {
          "$ref": "#/$defs/AbilityBlock"
        },
        "con": {
          "$ref": "#/$defs/AbilityBlock"
        },
        "int": {
          "$ref": "#/$defs/AbilityBlock"
        },
        "wis": {
          "$ref": "#/$defs/AbilityBlock"
        },
        "cha": {
          "$ref": "#/$defs/AbilityBlock"
        }
      },
      "required": [
        "str",
        "dex",
        "con",
        "int",
        "wis",
        "cha"
      ],
      "title": "AbilityScores",
      "type": "object"
    },
    "ArmorClass": {
      "properties": {
        "value": {
          "minimum": 0,
