      "description": "Where this monster occurrence came from.",
      "properties": {
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "source_title": {
          "title": "Source Title",
          "type": "string"
        },
        "book_title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
