            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Average"
        },
        "formula": {
          "anyOf": [
            {
              "$ref": "#/$defs/DiceFormula"
            },
            {
              "type": "null"
            }
          ],
          "default": null
